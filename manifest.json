{
  "manifest_version": 3,
  "name": "SecondRead",
  "version": "1.0",
  "description": "Adds cautious credibility context while reading news articles.",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon16.png",
    "128": "icons/icon16.png"
  },

  "action": {
    "default_icon": "icons/icon16.png",
    "default_title": "SecondRead"
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["Readability.js", "content.js"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "activeTab",
    "storage",
    "sidePanel",
    "scripting"
  ],

  "host_permissions": [
    "http://localhost:3000/*"
  ]
}
